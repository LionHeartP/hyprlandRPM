+  const auto status = requestJson("j/status");
+  if (status && status->is_object()) {
+      std::string provider = status->value("configProvider", "hyprlang");
+      m_useLua = (provider == "lua");
+      kLog.info("[workspace_hyprland] Provider detected: {}", provider);
+  } else {
+      kLog.warn("[workspace_hyprland] Failed to fetch Hyprland status JSON");
+  }
