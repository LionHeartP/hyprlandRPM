From 971c28a6d7e1e56a61cc020f8c3ec99a2318f8b5 Mon Sep 17 00:00:00 2001
From: LionHeartP <LionHeartP@proton.me>
Date: Fri, 1 May 2026 10:38:59 +0300
Subject: [PATCH] prepare for hyprland lua config

---
 meson.build                                   |  1 +
 .../hyprland/hyprland_config_backend.cpp      | 29 +++++++++++++++++++
 .../hyprland/hyprland_config_backend.h        |  5 ++++
 .../hyprland/hyprland_output_backend.cpp      | 11 ++++++-
 .../hyprland/hyprland_workspace_backend.cpp   |  8 ++++-
 src/shell/session/session_panel.cpp           |  7 +++--
 6 files changed, 57 insertions(+), 4 deletions(-)
 create mode 100644 src/compositors/hyprland/hyprland_config_backend.cpp
 create mode 100644 src/compositors/hyprland/hyprland_config_backend.h

diff --git a/meson.build b/meson.build
index 36350c075..8ea620017 100644
--- a/meson.build
+++ b/meson.build
@@ -548,6 +548,7 @@ _noctalia_sources = files(
   'src/compositors/ext_workspace/ext_workspace_output_backend.cpp',
   'src/compositors/ext_workspace/ext_workspace_backend.cpp',
   'src/compositors/keyboard_backend.cpp',
+  'src/compositors/hyprland/hyprland_config_backend.cpp',
   'src/compositors/hyprland/hyprland_output_backend.cpp',
   'src/compositors/hyprland/hyprland_workspace_backend.cpp',
   'src/compositors/hyprland/hyprland_keyboard_backend.cpp',
diff --git a/src/compositors/hyprland/hyprland_config_backend.cpp b/src/compositors/hyprland/hyprland_config_backend.cpp
new file mode 100644
index 000000000..c2ba6ba5d
--- /dev/null
+++ b/src/compositors/hyprland/hyprland_config_backend.cpp
@@ -0,0 +1,29 @@
+#include "compositors/hyprland/hyprland_config_backend.h"
+#include "core/process.h"
+#include <json.hpp>
+#include <optional>
+
+namespace compositors::hyprland {
+
+  bool isLua() {
+    static std::optional<bool> cachedIsLua;
+
+    if (cachedIsLua.has_value()) {
+      return *cachedIsLua;
+    }
+
+    const auto result = process::runSync({"hyprctl", "-j", "status"});
+
+    if (result) {
+      try {
+        auto j = nlohmann::json::parse(result.out);
+        cachedIsLua = (j.value("configProvider", "") == "lua");
+      } catch (...) {
+        return false;
+      }
+    }
+
+    return cachedIsLua.value_or(false);
+  }
+
+} // namespace compositors::hyprland
diff --git a/src/compositors/hyprland/hyprland_config_backend.h b/src/compositors/hyprland/hyprland_config_backend.h
new file mode 100644
index 000000000..a3597e5da
--- /dev/null
+++ b/src/compositors/hyprland/hyprland_config_backend.h
@@ -0,0 +1,5 @@
+#pragma once
+
+namespace compositors::hyprland {
+  bool isLua();
+}
diff --git a/src/compositors/hyprland/hyprland_output_backend.cpp b/src/compositors/hyprland/hyprland_output_backend.cpp
index 712a5da64..0326300af 100644
--- a/src/compositors/hyprland/hyprland_output_backend.cpp
+++ b/src/compositors/hyprland/hyprland_output_backend.cpp
@@ -1,9 +1,18 @@
+#include "compositors/hyprland/hyprland_config_backend.h"
 #include "compositors/hyprland/hyprland_output_backend.h"
 
+#include <format>
 #include "core/process.h"
 
 namespace compositors::hyprland {
 
-  bool setOutputPower(bool on) { return process::runAsync({"hyprctl", "dispatch", "dpms", on ? "on" : "off"}); }
+  bool setOutputPower(bool on) {
+    const std::string action = on ? "on" : "off";
+    if (isLua()) {
+      const std::string luaCmd = std::format("hl.dsp.dpms({{ action = \"{}\" }})", action);
+      return process::runAsync({"hyprctl", "dispatch", luaCmd});
+    }
+    return process::runAsync({"hyprctl", "dispatch", "dpms", action});
+  }
 
 } // namespace compositors::hyprland
diff --git a/src/compositors/hyprland/hyprland_workspace_backend.cpp b/src/compositors/hyprland/hyprland_workspace_backend.cpp
index 7fd577d5c..607b71820 100644
--- a/src/compositors/hyprland/hyprland_workspace_backend.cpp
+++ b/src/compositors/hyprland/hyprland_workspace_backend.cpp
@@ -1,3 +1,4 @@
+#include "compositors/hyprland/hyprland_config_backend.h"
 #include "compositors/hyprland/hyprland_workspace_backend.h"
 
 #include "core/log.h"
@@ -117,7 +118,12 @@ void HyprlandWorkspaceBackend::activate(const std::string& id) {
   }
 
   std::string response;
-  (void)sendRequest(std::format("dispatch workspace {}", id), response);
+  std::string cmd;
+  if (compositors::hyprland::isLua())
+      cmd = std::format("/dispatch hl.dsp.focus({{ workspace = '{}' }})", id);
+  else
+      cmd = std::format("dispatch workspace {}", id);
+  (void)sendRequest(cmd, response);
 }
 
 void HyprlandWorkspaceBackend::activateForOutput(wl_output* /*output*/, const std::string& id) { activate(id); }
diff --git a/src/shell/session/session_panel.cpp b/src/shell/session/session_panel.cpp
index 25def50d7..56ee373dd 100644
--- a/src/shell/session/session_panel.cpp
+++ b/src/shell/session/session_panel.cpp
@@ -1,6 +1,7 @@
 #include "shell/session/session_panel.h"
 
 #include "compositors/compositor_detect.h"
+#include "compositors/hyprland/hyprland_config_backend.h"
 #include "config/config_service.h"
 #include "core/log.h"
 #include "core/process.h"
@@ -43,8 +44,10 @@ namespace {
     // Prefer compositor-native exits where available.
     switch (compositors::detect()) {
     case compositors::CompositorKind::Hyprland:
-      if (process::runSync({"hyprctl", "dispatch", "exit"})) {
-        return true;
+      if (compositors::hyprland::isLua()) {
+        if (process::runSync({"hyprctl", "dispatch", "hl.dsp.exit()"})) return true;
+      } else {
+        if (process::runSync({"hyprctl", "dispatch", "exit"})) return true;
       }
       break;
     case compositors::CompositorKind::Sway:
